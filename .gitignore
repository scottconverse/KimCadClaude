# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# KimCad — bundled binaries are fetched, never committed
/tools/
# Runtime render/slice artifacts
/output/
*.gcode

# Frontend (Node is build-time only; the built SPA lands in src/kimcad/web and IS committed)
frontend/node_modules/
frontend/dist/
frontend/.vite/
# A stray root-level node_modules / vitest cache can appear if a tool runs at the repo root —
# never commit it (the real deps live under frontend/).
node_modules/
.vite/
frontend/*.tsbuildinfo

# Editor / OS
.vscode/
.idea/
Thumbs.db
.DS_Store

# Local config overrides + secrets
config/local.yaml
.env
*.key

# Session/preview tooling (Claude Code) — never commit machine-specific launch configs
.claude/
