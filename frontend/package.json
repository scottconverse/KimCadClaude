{
  "name": "kimcad-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "KimCad SPA (React + TypeScript + Vite). Build-time only — the compiled static files are served by KimCad's local Python server; Node never ships at runtime.",
  "scripts": {
    "dev": "vite",
    "prebuild": "rimraf ../src/kimcad/web/assets",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.6.3",
    "vite": "^8.0.15",
    "vitest": "^4.1.8"
  }
}
