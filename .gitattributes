# Normalize line endings across Windows/macOS/Linux clones.
* text=auto eol=lf

# Explicitly text (LF) — source and config.
*.py    text eol=lf
*.scad  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf

# Binary render/slice artifacts — never line-ending-converted.
*.stl   binary
*.3mf   binary
*.gcode binary
*.png   binary
